# URL WebSocket Python server
# Development:      ws://localhost:8765
# LAN production:   ws://192.168.1.100:8765
# Internet (ngrok): ws://0.tcp.ngrok.io:PORT
NEXT_PUBLIC_WS_URL=ws://localhost:8765
NEXT_PUBLIC_APP_NAME=sweenex
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_MIN_CONFIDENCE=0.30
NEXT_PUBLIC_MAX_ROUTERS=8
